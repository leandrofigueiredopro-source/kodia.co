{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Plan": {
      "title": "Plan",
      "description": "Generated strategic plan for a SaaS idea",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "idea": { "type": "string" },
        "steps": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "content": { "type": "string" }
            }
          }
        },
        "megaPrompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "idea", "steps", "megaPrompt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/plans/{planId}": {
      "schema": "Plan",
      "description": "User's generated SaaS plans"
    }
  }
}
